#!/usr/bin/env bash

set -Eeuo pipefail

if [ "${DOTFILES_DEBUG:-}" ]; then
    set -x
fi

function decrypt_age_private_key() {
    local age_dir
    local age_src_key
    local age_dst_key
    local tmp_age_dst_key

    if "${CI:-false}"; then
        # age is currently required tty. The CI does not have tty so return early
        return 0 # early return
    fi

    age_dir="${HOME}/.config/age"
    age_src_key="{{ .chezmoi.sourceDir }}/.key.txt.age"
    age_dst_key="${age_dir}/key.txt"
    tmp_age_dst_key="${age_dst_key}.tmp"

    if [ ! -f "${age_dst_key}" ]; then
        if [ ! -f "${age_src_key}" ]; then
            echo "Warning: ${age_src_key} is missing. Skipping private encrypted dotfiles setup." >&2
            return 0
        fi

        mkdir -p "${age_dir}"

        echo "Decrypting ${age_src_key} to ${age_dst_key}"
        rm -f "${tmp_age_dst_key}"
        if ! chezmoi age decrypt --output "${tmp_age_dst_key}" --passphrase "${age_src_key}"; then
            rm -f "${tmp_age_dst_key}"
            echo "Warning: Failed to decrypt age identity key. Skipping private encrypted dotfiles setup." >&2
            return 0
        fi
        chmod 600 "${tmp_age_dst_key}"
        mv "${tmp_age_dst_key}" "${age_dst_key}"
    fi
}

function main() {
    decrypt_age_private_key
}

if [[ "${BASH_SOURCE[0]}" == "${0}" ]]; then
    main
fi
