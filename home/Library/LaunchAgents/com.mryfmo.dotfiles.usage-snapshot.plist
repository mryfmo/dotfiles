<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.mryfmo.dotfiles.usage-snapshot</string>
    <key>ProgramArguments</key>
    <array>
        <string>/usr/bin/make</string>
        <string>-C</string>
        <string>/Users/mryfmo/Workspace/dotfiles</string>
        <string>usage-snapshot</string>
        <string>usage-report</string>
    </array>
    <key>StartCalendarInterval</key>
    <dict>
        <key>Weekday</key>
        <integer>2</integer>
        <key>Hour</key>
        <integer>9</integer>
        <key>Minute</key>
        <integer>0</integer>
    </dict>
    <key>StandardOutPath</key>
    <string>/Users/mryfmo/.config/dotfiles/usage-review.log</string>
    <key>StandardErrorPath</key>
    <string>/Users/mryfmo/.config/dotfiles/usage-review.log</string>
</dict>
</plist>
