#!/usr/bin/env bash

# @file herdr-agents
# @brief Build or attach Claude Code, Codex, and Yazi panes in Herdr.
# @description
#   Full mode creates or repairs an agents workspace. Attach mode adds Codex
#   and Yazi around Claude in the current Herdr pane without restarting Claude.
# @option --attach Attach the current Claude pane to its Herdr workspace layout.
# @arg DIR Optional directory for the Herdr workspace. Defaults to the current directory.
# @example
#   herdr-agents ~/Workspace/dotfiles
# @example
#   herdr-agents --attach

set -euo pipefail

# @description Print usage information.
function usage() {
    cat << 'USAGE'
Usage: herdr-agents [DIR]
       herdr-agents --attach

Create a Herdr workspace for DIR, start Claude Code left of Codex, add an
interactive Yazi file pane on the far right, and open DIR in Zed when
available. Herdr, jq, Claude Code, Codex, and Yazi are required. DIR defaults
to the current directory. Attach mode uses the current Herdr pane for Claude.
USAGE
}

# @description Extract a Herdr workspace id from workspace JSON on stdin.
function json_workspace_id() {
    jq -r '.result.workspace.workspace_id // .workspace.workspace_id // .workspace_id // empty' 2> /dev/null || true
}

# @description Extract the initial Herdr pane id from workspace JSON on stdin.
function json_root_pane_id() {
    jq -r '.result.root_pane.pane_id // .root_pane.pane_id // .pane_id // empty' 2> /dev/null || true
}

# @description Extract an agent pane id from Herdr JSON on stdin.
function json_agent_pane_id() {
    jq -r '.result.pane.pane_id // .result.agent.pane_id // .result.terminal.pane_id // .result.pane_id // .pane.pane_id // .agent.pane_id // .terminal.pane_id // .pane_id // empty' 2> /dev/null || true
}

# @description Build the Claude command run in the orchestrator pane.
function claude_command() {
    printf "%s\n" "CLICOLOR_FORCE=1 FORCE_COLOR=1 HERDR_AGENTS_LAYOUT=managed claude --model 'claude-fable-5[1m]' --effort high"
}

# @description Start Claude in an existing pane.
# @arg $1 pane_id Herdr pane id to reuse.
function start_claude_in_pane() {
    local pane_id="$1"

    herdr pane rename "${pane_id}" claude-orchestrator
    herdr pane run "${pane_id}" "$(claude_command)"
}

# @description Start Codex in a workspace split and return its pane id.
# @arg $1 workspace_id Herdr workspace id.
# @arg $2 agent_name Herdr Codex agent registration name.
# @arg $3 workdir Working directory for Codex.
function start_codex_agent() {
    local workspace_id="$1"
    local agent_name="$2"
    local workdir="$3"
    local codex_agent_json
    local codex_pane_id

    if ! codex_agent_json="$(
        herdr agent start "${agent_name}" --cwd "${workdir}" --workspace "${workspace_id}" --split right --env CLICOLOR_FORCE=1 --env FORCE_COLOR=1 --no-focus -- \
            codex --sandbox workspace-write -m gpt-5.6-sol -c model_reasoning_effort=high
    )"; then
        printf 'Failed to start Codex agent %s: %s\n' "${agent_name}" "${codex_agent_json}" >&2
        return 1
    fi

    codex_pane_id="$(printf '%s\n' "${codex_agent_json}" | json_agent_pane_id)"
    if [[ -z ${codex_pane_id} ]]; then
        codex_pane_id="$(herdr agent get "${agent_name}" | json_agent_pane_id)"
    fi
    if [[ -z ${codex_pane_id} ]]; then
        printf 'Unable to read Codex pane id for Herdr agent: %s\n' "${agent_name}" >&2
        return 1
    fi
    herdr pane rename "${codex_pane_id}" codex-worker > /dev/null
    printf '%s\n' "${codex_pane_id}"
}

# @description Start the required Yazi process in an existing pane.
# @arg $1 pane_id Herdr pane id to reuse.
function start_yazi_in_pane() {
    local pane_id="$1"

    herdr pane run "${pane_id}" yazi
}

# @description Start the required Yazi files pane in a right split.
# @arg $1 pane_id Herdr pane id to split.
# @arg $2 workdir Directory listed in the files pane.
# @arg $3 ratio Fraction of the original pane to retain.
function start_files_pane() {
    local pane_id="$1"
    local workdir="$2"
    local ratio="$3"
    local files_pane_json
    local files_pane_id

    if ! files_pane_json="$(herdr pane split "${pane_id}" --direction right --ratio "${ratio}" --cwd "${workdir}" --no-focus)"; then
        printf 'Failed to split files pane from %s: %s\n' "${pane_id}" "${files_pane_json}" >&2
        return 1
    fi
    files_pane_id="$(printf '%s\n' "${files_pane_json}" | json_agent_pane_id)"
    if [[ -z ${files_pane_id} ]]; then
        printf 'Unable to read files pane id from: %s\n' "${files_pane_json}" >&2
        return 1
    fi
    herdr pane rename "${files_pane_id}" files || return 1
    start_yazi_in_pane "${files_pane_id}"
}

# @description Ensure one files pane exists and runs Yazi.
# @arg $1 json Herdr pane list JSON.
# @arg $2 pane_id Herdr pane id to split when the files pane is missing.
# @arg $3 workdir Directory listed in the files pane.
# @arg $4 ratio Fraction of the split pane to retain.
function ensure_files_pane() {
    local panes_json="$1"
    local split_pane_id="$2"
    local workdir="$3"
    local ratio="$4"
    local files_pane
    local files_pane_status

    files_pane="$(files_pane_id "${panes_json}")"
    if [[ ${files_pane} == *$'\n'* ]]; then
        printf 'Multiple Herdr files panes are ambiguous; refusing repair.\n' >&2
        return 1
    fi
    if [[ -z ${files_pane} ]]; then
        start_files_pane "${split_pane_id}" "${workdir}" "${ratio}"
    elif pane_runs_yazi "${files_pane}"; then
        return 0
    else
        files_pane_status="$?"
        if [[ ${files_pane_status} -ne 1 ]]; then
            return "${files_pane_status}"
        fi
        start_yazi_in_pane "${files_pane}"
    fi
}

# @description Find an existing agents workspace for a workdir.
# @arg $1 label Expected Herdr workspace label.
# @arg $2 workdir Absolute workdir path.
function find_existing_workspace() {
    local label="$1"
    local workdir="$2"
    local workspace_list_json
    local workspace_id
    local panes_json

    workspace_list_json="$(herdr workspace list)"
    while IFS= read -r workspace_id; do
        [[ -n ${workspace_id} ]] || continue
        if ! panes_json="$(herdr pane list --workspace "${workspace_id}")"; then
            continue
        fi
        if printf '%s\n' "${panes_json}" | jq -e --arg cwd "${workdir}" '.result.panes[]? | select(.cwd == $cwd)' > /dev/null; then
            printf '%s\n' "${workspace_id}"
            return 0
        fi
    done < <(printf '%s\n' "${workspace_list_json}" | jq -r --arg label "${label}" '.result.workspaces[]? | select(.label == $label) | .workspace_id // empty')
}

# @description Return success when a Claude pane is present.
# @arg $1 json Herdr pane list JSON.
function has_claude_pane() {
    local panes_json="$1"

    printf '%s\n' "${panes_json}" | jq -e '.result.panes[]? | select(.agent == "claude")' > /dev/null
}

# @description Return every labeled files pane id.
# @arg $1 json Herdr pane list JSON.
function files_pane_id() {
    local panes_json="$1"

    printf '%s\n' "${panes_json}" | jq -r '.result.panes[]? | select(.label == "files") | .pane_id // empty'
}

# @description Classify a pane as live Yazi, validly stale, or inspection error.
# @arg $1 pane_id Herdr pane id to inspect.
# @exitcode 0 A live Yazi foreground process exists.
# @exitcode 1 Process data is valid and Yazi is absent.
# @exitcode 2 Process data could not be inspected safely.
function pane_runs_yazi() {
    local pane_id="$1"
    local process_info_json

    if ! process_info_json="$(herdr pane process-info --pane "${pane_id}")"; then
        printf 'Failed to inspect files pane process: %s\n' "${pane_id}" >&2
        return 2
    fi
    if ! printf '%s\n' "${process_info_json}" | jq -e \
        '.result.process_info.foreground_processes as $processes
         | ($processes | type == "array")
           and all($processes[]; (type == "object") and (.name | type == "string"))' > /dev/null; then
        printf 'Invalid files pane process response: %s\n' "${pane_id}" >&2
        return 2
    fi
    if printf '%s\n' "${process_info_json}" | jq -e '.result.process_info.foreground_processes[] | select(.name == "yazi")' > /dev/null; then
        return 0
    fi
    return 1
}

# @description Return the Codex pane id when the registered agent points to a live pane.
# @arg $1 agent_name Herdr Codex agent registration name.
# @arg $2 json Herdr pane list JSON.
function live_codex_pane_id() {
    local agent_name="$1"
    local panes_json="$2"
    local agent_json
    local pane_id

    if ! agent_json="$(herdr agent get "${agent_name}" 2> /dev/null)"; then
        return 1
    fi
    pane_id="$(printf '%s\n' "${agent_json}" | json_agent_pane_id)"
    [[ -n ${pane_id} ]] || return 1
    printf '%s\n' "${panes_json}" | jq -e --arg pane_id "${pane_id}" '.result.panes[]? | select(.pane_id == $pane_id)' > /dev/null || return 1
    printf '%s\n' "${pane_id}"
}

# @description Return pane-list JSON filtered to the tab containing a pane.
# @arg $1 json Herdr pane list JSON.
# @arg $2 pane_id Pane whose tab should be retained.
function panes_on_pane_tab() {
    local panes_json="$1"
    local pane_id="$2"

    printf '%s\n' "${panes_json}" | jq -ce --arg pane_id "${pane_id}" \
        '.result.panes as $panes
         | ($panes | map(select(.pane_id == $pane_id and (.tab_id | type) == "string"))) as $current
         | if ($current | length) == 1
           then .result.panes = [$panes[] | select(.tab_id == $current[0].tab_id)]
           else error("unable to identify pane tab")
           end'
}

# @description Return success when attach mode can account for every pane.
# @arg $1 json Herdr pane list JSON.
# @arg $2 pane_id Current Claude pane id.
# @arg $3 pane_id Live Codex pane id, or empty when missing.
function attach_panes_are_unambiguous() {
    local panes_json="$1"
    local claude_pane_id="$2"
    local codex_pane_id="$3"
    local files_pane

    files_pane="$(files_pane_id "${panes_json}")"
    [[ ${files_pane} != *$'\n'* ]] || return 1
    printf '%s\n' "${panes_json}" | jq -e \
        --arg claude "${claude_pane_id}" \
        --arg codex "${codex_pane_id}" \
        --arg files "${files_pane}" \
        '.result.panes | map(.pane_id) as $actual
         | ([$claude, $codex, $files] | map(select(length > 0)) | unique) as $managed
         | ($actual | length) == ($managed | length)
           and all($actual[]; . as $pane_id | ($managed | index($pane_id)) != null)' > /dev/null
}

# @description Repair the left-to-right order of the three attach-mode panes.
# @arg $1 json Herdr pane list JSON.
# @arg $2 pane_id Current Claude pane id.
# @arg $3 pane_id Live Codex pane id.
function repair_attach_pane_order() {
    local panes_json="$1"
    local claude_pane_id="$2"
    local codex_pane_id="$3"
    local files_pane
    local layout_json
    local current_order
    local left_pane
    local middle_pane

    files_pane="$(files_pane_id "${panes_json}")"
    if [[ -z ${files_pane} || -z ${codex_pane_id} ]] || ! attach_panes_are_unambiguous "${panes_json}" "${claude_pane_id}" "${codex_pane_id}"; then
        printf 'Herdr attach panes are ambiguous or include unmanaged panes; refusing order repair.\n' >&2
        return 0
    fi
    if ! layout_json="$(herdr pane layout --pane "${claude_pane_id}")"; then
        printf 'Unable to inspect Herdr attach pane order; refusing order repair.\n' >&2
        return 0
    fi
    if ! current_order="$(
        printf '%s\n' "${layout_json}" | jq -er \
            --arg claude "${claude_pane_id}" \
            --arg codex "${codex_pane_id}" \
            --arg files "${files_pane}" \
            '[.result.layout.panes[]? | select(.pane_id == $claude or .pane_id == $codex or .pane_id == $files)] as $panes
             | if ($panes | length) == 3
                  and all($panes[]; .rect.x | type == "number")
                  and ([$panes[].rect.x] | unique | length) == 3
               then ($panes | sort_by(.rect.x) | map(.pane_id) | @tsv)
               else error("ambiguous pane layout")
               end'
    )"; then
        printf 'Herdr attach pane layout is ambiguous; refusing order repair.\n' >&2
        return 0
    fi

    IFS=$'\t' read -r left_pane middle_pane _ <<< "${current_order}"
    if [[ ${left_pane} != "${claude_pane_id}" ]]; then
        herdr pane swap --source-pane "${left_pane}" --target-pane "${claude_pane_id}"
        if [[ ${middle_pane} == "${claude_pane_id}" ]]; then
            middle_pane="${left_pane}"
        fi
    fi
    if [[ ${middle_pane} != "${codex_pane_id}" ]]; then
        herdr pane swap --source-pane "${middle_pane}" --target-pane "${codex_pane_id}"
    fi
}

# @description Skip $HOME or ensure Codex turn delivery and report ambiguity.
# @arg $1 workdir Repository path used for repo-scoped agmsg registration.
function bootstrap_agmsg() {
    local workdir="$1"

    if [[ "$(cd -- "${workdir}" && pwd -P)" == "$(cd -- "${HOME}" && pwd -P)" ]]; then
        printf "Skipping agmsg bootstrap for \$HOME; use a repository directory instead.\n" >&2
        return 0
    fi

    local scripts="${HOME}/.agents/skills/agmsg/scripts"
    local delivery="${scripts}/delivery.sh"
    local identities="${scripts}/identities.sh"
    local hooks_file="${workdir}/.codex/hooks.json"
    local log_file="${HOME}/.config/herdr/herdr-agents.log"
    local identity_list

    [[ -f ${delivery} ]] || return 0
    if ! { [[ -f ${hooks_file} ]] && jq -e \
        'any(.hooks.Stop[]?.hooks[]?; ((.bash // .command // "") | contains("agmsg/scripts/check-inbox.sh")))' \
        "${hooks_file}" > /dev/null 2>&1; }; then
        if "${delivery}" set turn codex "${workdir}" >> "${log_file}" 2>&1; then
            printf 'Codex loads the new repo hook only after the project .codex layer is trusted; run /hooks or trust the repo in Codex.\n' >&2
        fi
    fi

    if [[ ! -f ${identities} ]] || ! identity_list="$("${identities}" "${workdir}" codex 2>> "${log_file}")"; then
        return 0
    fi
    if [[ -z ${identity_list} ]]; then
        printf 'No agmsg Codex identity for %s; run: %s/join.sh <team> <agent-name> codex "%s"\n' \
            "${workdir}" "${scripts}" "${workdir}" >&2
    elif [[ ${identity_list} == *$'\n'* ]]; then
        printf 'Multiple agmsg Codex identities are registered for %s; worker identity is ambiguous.\n' "${workdir}" >&2
    fi
}

# @description Return the first pane id without an attached agent.
# @arg $1 json Herdr pane list JSON.
# @arg $2 pane_id Optional pane id to exclude.
function empty_pane_id() {
    local panes_json="$1"
    local exclude_pane_id="${2:-}"

    printf '%s\n' "${panes_json}" | jq -r --arg exclude "${exclude_pane_id}" '.result.panes[]? | select((.agent? // "") == "" and .label? != "files" and .pane_id != $exclude) | .pane_id // empty' | head -n 1
}

# @description Require a command before starting a partial layout.
# @arg $1 string Command name.
function require_command() {
    local command_name="$1"

    if ! command -v "${command_name}" > /dev/null 2>&1; then
        printf '%s command not found\n' "${command_name}" >&2
        exit 127
    fi
}

if [[ ${1:-} == "--help" || ${1:-} == "-h" ]]; then
    usage
    exit 0
fi

attach_mode=false
if [[ ${1:-} == "--attach" ]]; then
    attach_mode=true
    shift
    if [[ -z ${HERDR_ENV:-} || -z ${HERDR_PANE_ID:-} || -z ${HERDR_WORKSPACE_ID:-} ]]; then
        exit 0
    fi
    [[ ${HERDR_AGENTS_LAYOUT:-} == managed ]] && exit 0
fi

if { [[ ${attach_mode} == true ]] && [[ $# -gt 0 ]]; } || [[ $# -gt 1 ]]; then
    usage >&2
    exit 2
fi

require_command herdr
require_command jq
require_command codex
require_command yazi
if [[ ${attach_mode} == false ]]; then
    require_command claude
fi

if [[ ${attach_mode} == true ]]; then
    workdir="$PWD"
else
    workdir="${1:-$PWD}"
fi
cd -- "${workdir}"
workdir="$PWD"

if [[ ${attach_mode} == true ]]; then
    workspace_id="${HERDR_WORKSPACE_ID}"
    claude_pane_id="${HERDR_PANE_ID}"
    codex_agent_name="codex-worker-${workspace_id}"
    panes_json="$(herdr pane list --workspace "${workspace_id}")"
    workspace_codex_pane_id="$(live_codex_pane_id "${codex_agent_name}" "${panes_json}")" || workspace_codex_pane_id=""
    if ! panes_json="$(panes_on_pane_tab "${panes_json}" "${claude_pane_id}")"; then
        printf 'Unable to identify the current Herdr tab; refusing attach repair.\n' >&2
        exit 0
    fi
    codex_pane_id="$(live_codex_pane_id "${codex_agent_name}" "${panes_json}")" || codex_pane_id=""

    if ! attach_panes_are_unambiguous "${panes_json}" "${claude_pane_id}" "${codex_pane_id}"; then
        printf 'Herdr attach panes are ambiguous or include unmanaged panes; refusing repair.\n' >&2
        exit 0
    fi
    if [[ -z ${codex_pane_id} && -n ${workspace_codex_pane_id} ]]; then
        printf 'The existing Codex agent is on another Herdr tab; refusing to start a duplicate.\n' >&2
    fi

    if ! printf '%s\n' "${panes_json}" | jq -e --arg pane_id "${claude_pane_id}" '.result.panes[]? | select(.pane_id == $pane_id and .label == "claude-orchestrator")' > /dev/null; then
        herdr pane rename "${claude_pane_id}" claude-orchestrator
    fi

    ensure_files_pane "${panes_json}" "${claude_pane_id}" "${workdir}" 0.8
    if [[ -z ${codex_pane_id} && -z ${workspace_codex_pane_id} ]]; then
        codex_pane_id="$(start_codex_agent "${workspace_id}" "${codex_agent_name}" "${workdir}")"
    fi
    panes_json="$(herdr pane list --workspace "${workspace_id}")"
    if ! panes_json="$(panes_on_pane_tab "${panes_json}" "${claude_pane_id}")"; then
        printf 'Unable to identify the current Herdr tab; refusing order repair.\n' >&2
        exit 0
    fi
    repair_attach_pane_order "${panes_json}" "${claude_pane_id}" "${codex_pane_id}"
    bootstrap_agmsg "${workdir}"

    printf 'Herdr agents workspace: %s\n' "${workspace_id}"
    exit 0
fi

workspace_label="$(basename "${workdir}") agents"
existing_workspace_id="$(find_existing_workspace "${workspace_label}" "${workdir}")"

if [[ -n ${existing_workspace_id} ]]; then
    workspace_id="${existing_workspace_id}"
    codex_agent_name="codex-worker-${workspace_id}"
    panes_json="$(herdr pane list --workspace "${workspace_id}")"
    codex_pane_id="$(live_codex_pane_id "${codex_agent_name}" "${panes_json}")" || codex_pane_id=""

    if [[ -z ${codex_pane_id} ]]; then
        codex_pane_id="$(start_codex_agent "${workspace_id}" "${codex_agent_name}" "${workdir}")"
        panes_json="$(herdr pane list --workspace "${workspace_id}")"
    fi

    if ! has_claude_pane "${panes_json}"; then
        claude_pane_id="$(empty_pane_id "${panes_json}" "${codex_pane_id}")"
        if [[ -z ${claude_pane_id} ]]; then
            claude_pane_json="$(herdr pane split "${codex_pane_id}" --direction right --no-focus)"
            claude_pane_id="$(printf '%s\n' "${claude_pane_json}" | json_agent_pane_id)"
            [[ -n ${claude_pane_id} ]] || claude_pane_id="$(printf '%s\n' "${claude_pane_json}" | jq -r '.result.pane.pane_id // .pane.pane_id // .pane_id // empty')"
            if [[ -z ${claude_pane_id} ]]; then
                printf 'Unable to read Claude repair pane id for Herdr workspace: %s\n' "${workspace_id}" >&2
                exit 1
            fi
            herdr pane swap --pane "${claude_pane_id}" --direction left
        fi
        start_claude_in_pane "${claude_pane_id}"
    fi

    ensure_files_pane "${panes_json}" "${codex_pane_id}" "${workdir}" 0.6
    bootstrap_agmsg "${workdir}"

    herdr workspace focus "${workspace_id}"
    printf 'Herdr agents workspace: %s\n' "${workspace_id}"
    exit 0
fi

workspace_json="$(herdr workspace create --cwd "${workdir}" --label "${workspace_label}" --focus)"
workspace_id="$(printf '%s\n' "${workspace_json}" | json_workspace_id)"
root_pane_id="$(printf '%s\n' "${workspace_json}" | json_root_pane_id)"
codex_agent_name="codex-worker-${workspace_id}"

if [[ -z ${workspace_id} ]]; then
    printf 'Unable to read Herdr workspace id from: %s\n' "${workspace_json}" >&2
    exit 1
fi

if [[ -z ${root_pane_id} ]]; then
    printf 'Unable to read Herdr root pane id from: %s\n' "${workspace_json}" >&2
    exit 1
fi

start_claude_in_pane "${root_pane_id}"
start_files_pane "${root_pane_id}" "${workdir}" 0.8
start_codex_agent "${workspace_id}" "${codex_agent_name}" "${workdir}" > /dev/null
bootstrap_agmsg "${workdir}"

if command -v zed > /dev/null 2>&1; then
    zed "${workdir}" > /dev/null 2>&1 &
fi

printf 'Herdr agents workspace: %s\n' "${workspace_id}"
