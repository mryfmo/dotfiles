#!/usr/bin/env bash

# @file herdr-agents
# @brief Open a Herdr workspace with Claude Code above Codex.
# @description
#   Creates a Herdr workspace for a directory, starts Claude Code and Codex in
#   stacked panes, and opens the same directory in Zed when the `zed` CLI exists.

set -euo pipefail

# @description Print usage information.
function usage() {
    cat <<'USAGE'
Usage: herdr-agents [DIR]

Create a Herdr workspace for DIR, start Claude Code above Codex, and open DIR
in Zed when available. DIR defaults to the current directory.
USAGE
}

# @description Extract the first JSON id value from stdin.
function json_id() {
    sed -n 's/.*"id"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\1/p' | head -n 1
}

# @description Require a command before starting a partial layout.
# @arg $1 string Command name.
function require_command() {
    local command_name="$1"

    if ! command -v "${command_name}" >/dev/null 2>&1; then
        printf '%s command not found\n' "${command_name}" >&2
        exit 127
    fi
}

if [[ ${1:-} == "--help" || ${1:-} == "-h" ]]; then
    usage
    exit 0
fi

if [[ $# -gt 1 ]]; then
    usage >&2
    exit 2
fi

require_command herdr
require_command claude
require_command codex

workdir="${1:-$PWD}"
cd -- "${workdir}"
workdir="$PWD"
workspace_label="$(basename "${workdir}") agents"

workspace_json="$(herdr workspace create --cwd "${workdir}" --label "${workspace_label}" --focus)"
workspace_id="$(printf '%s\n' "${workspace_json}" | json_id)"

if [[ -z ${workspace_id} ]]; then
    printf 'Unable to read Herdr workspace id from: %s\n' "${workspace_json}" >&2
    exit 1
fi

herdr agent start claude --cwd "${workdir}" --workspace "${workspace_id}" --env CLICOLOR_FORCE=1 --env FORCE_COLOR=1 --focus -- claude
herdr agent start codex --cwd "${workdir}" --workspace "${workspace_id}" --split down --env CLICOLOR_FORCE=1 --env FORCE_COLOR=1 --focus -- codex

if command -v zed >/dev/null 2>&1; then
    zed "${workdir}" >/dev/null 2>&1 &
fi

printf 'Herdr agents workspace: %s\n' "${workspace_id}"
