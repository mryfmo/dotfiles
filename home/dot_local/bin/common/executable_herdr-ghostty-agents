#!/usr/bin/env bash

# @file herdr-ghostty-agents
# @brief Start the default Herdr agent workspace from Ghostty.
# @description
#   Creates the Claude Code over Codex workspace, then attaches the current
#   terminal to Herdr so Ghostty stays on the Herdr UI.

set -euo pipefail

workdir="${1:-$PWD}"

herdr-agents "${workdir}" > /dev/null
exec herdr
