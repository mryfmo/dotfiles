#!/usr/bin/env zsh

# @file home/dot_zshenv
# @brief Configure environment variables loaded before zsh startup.
# @description
#   Disables Claude Code's built-in auto-updater so Claude Code remains managed
#   by the mise-controlled update flow.
export DISABLE_AUTOUPDATER=1

readonly ZSHENV_PRIVATE="${HOME}/.zshenv_private"

if [ -f "${ZSHENV_PRIVATE}" ]; then
    source "${ZSHENV_PRIVATE}"
fi
